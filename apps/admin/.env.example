# ============================================
# 환경 변수 예시 파일 (Admin App)
# ============================================
# 이 파일을 복사하여 .env.local 또는 .env.development.local 등을 생성하세요.

# 앱 기본 정보
NEXT_PUBLIC_APP_NAME=Admin Dashboard
NEXT_PUBLIC_APP_VERSION=0.1.0

# API 서버 설정
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Supabase (선택 사항)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Firebase Web Push (FCM)
# Firebase 콘솔 → 프로젝트 설정 → 일반 → 웹 앱에서 복사
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase 콘솔 → 프로젝트 설정 → 클라우드 메시징 → 웹 푸시 인증서(VAPID 공개 키)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Sentry 에러 모니터링
# Sentry 프로젝트 설정에서 DSN 복사
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=
SENTRY_ORG=jhg-qn
SENTRY_PROJECT=admin
