# API URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Capacitor Remote WebView URL
# Set this when syncing/running native apps. Use your deployed delivery web URL in production.
CAPACITOR_SERVER_URL=http://localhost:3001

# Toss Payments 결제위젯 연동 키
# 결제위젯 SDK는 API 개별 연동 키(test_ck_/test_sk_)가 아니라 widget key(test_gck_/test_gsk_)를 사용합니다.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_...

# Store ID (실제 운영에서는 매장별로 다르게 설정)
NEXT_PUBLIC_STORE_ID=store-1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry 에러 모니터링
# Sentry 프로젝트 설정에서 DSN 복사
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=
SENTRY_ORG=jhg-qn
SENTRY_PROJECT=delivery-customer
