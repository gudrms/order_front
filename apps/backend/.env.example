# ===========================================
# Backend (.env.example)
# ===========================================
# 이 파일을 복사하여 .env / .env.local 등을 생성하세요.

# ----- Node Environment -----
NODE_ENV=development

# ----- Supabase Database -----
# Supabase 프로젝트 설정 > Database > Connection String에서 확인
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ----- Supabase API Keys -----
# Supabase 프로젝트 설정 > API > Project API keys
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ----- CORS -----
# 운영(NODE_ENV=production)에서는 아래 5개 tacomole.kr 도메인 + Capacitor scheme이 자동 허용됨.
# 추가 도메인(스테이징, vercel preview 등)이 필요하면 FRONTEND_URLS에 콤마 구분으로 나열.
# 단일 origin은 FRONTEND_URL로 지정 가능 (기존 호환).
# 예: FRONTEND_URLS="https://staging.tacomole.kr,https://preview-xxx.vercel.app"
FRONTEND_URL=""
FRONTEND_URLS=""

# ----- Sentry -----
# Sentry 프로젝트 설정에서 DSN 복사
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_ENVIRONMENT=development

# ----- Toss Place (POS 연동) -----
TOSS_ACCESS_KEY="your_access_key"
TOSS_ACCESS_SECRET="your_access_secret"
TOSS_MERCHANT_ID="your_merchant_id"

# ----- Toss Payments (배달앱 결제) -----
# 결제 모듈은 TOSS_PAYMENTS_SECRET_KEY 우선, 없으면 TOSS_ACCESS_SECRET 사용
TOSS_PAYMENTS_SECRET_KEY="test_sk_..."

# Toss Place 일반 API (POS 외)
TOSS_API_KEY=""
TOSS_BASE_URL="https://dum.toss.co.kr/api"

# ----- POS Plugin -----
# Toss POS 플러그인이 /pos 엔드포인트 호출 시 x-pos-api-key 헤더에 이 값을 보냄
POS_INTEGRATION_API_KEY="change-me"

# ----- Redis (Rate Limiting 분산 저장소) -----
# Vercel 다중 인스턴스 환경에서 Throttler 카운터를 공유하기 위한 Redis.
# 미설정 시 in-memory 폴백 (개발 환경에서는 생략 가능).
# Upstash Redis 가입 후 → 프로젝트 생성 → "ioredis" 탭 URL 복사
# 형식: rediss://default:PASSWORD@HOST.upstash.io:6379
REDIS_URL=""

# ----- 내부 운영 엔드포인트 보호 시크릿 -----
# queue/process-once, payments/toss/expire-pending, payments/reconcile 등 내부 운영 엔드포인트가
# 이 값과 일치하는 x-internal-secret 헤더를 요구함. 운영자는 cron/scheduler에서 이 헤더를 동봉.
INTERNAL_JOB_SECRET="change-me"
