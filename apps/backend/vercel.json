{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "maxDuration": 30
        },
        "api/queue.ts": {
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/api/v1/queue/(.*)",
            "dest": "/api/queue",
            "methods": [
                "POST",
                "OPTIONS"
            ]
        },
        {
            "src": "/(.*)",
            "dest": "/api/index",
            "methods": [
                "GET",
                "POST",
                "PUT",
                "PATCH",
                "DELETE",
                "OPTIONS"
            ]
        }
    ]
}
