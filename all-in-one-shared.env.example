# ==========================================
# 모노레포 전체 공통 환경변수 (All-in-One) — 예시 파일
# 실값은 all-in-one-shared.env.local 에 작성하세요 (gitignore됨)
# Vercel Shared Environment Variables에서 Import
# 대상 프로젝트:
# order-backend, order-admin, order-delivery, order-front-frontend, order-website
# ==========================================

# ----------------- 프론트/백엔드 공통 -----------------
# 백엔드 API 주소
NEXT_PUBLIC_API_URL=
# 기본 매장 ID (MVP)
NEXT_PUBLIC_STORE_ID=
# 브랜드 웹사이트에서 배달 앱으로 이동할 때 사용하는 주소
NEXT_PUBLIC_DELIVERY_URL=

# ----------------- Supabase (DB/인증) -----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----------------- Toss 결제 및 POS -----------------
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_ACCESS_KEY=
TOSS_ACCESS_SECRET=
TOSS_MERCHANT_ID=
POS_INTEGRATION_API_KEY=

# ----------------- 브랜드 웹사이트 전용 (메일, 지도) -----------------
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ----------------- 백엔드 전용 시크릿 -----------------
INTERNAL_JOB_SECRET=
SENTRY_DSN=

# ----------------- Backend runtime -----------------
DATABASE_URL=
REDIS_URL=
FRONTEND_URLS=
FRONTEND_URL=
PORT=
LOG_LEVEL=
BACKEND_QUEUE_NAME=
BACKEND_QUEUE_MAX_ATTEMPTS=
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_SMS_WEBHOOK_URL=

# ----------------- Firebase client (Admin web push) -----------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_ANDROID_PACKAGE_NAME=
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_BUNDLE_ID=
FIREBASE_IOS_API_KEY=

# ----------------- Firebase admin (Backend push) -----------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ----------------- Sentry build/runtime -----------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_APP_VERSION=

# ----------------- Optional app routing/defaults -----------------
NEXT_PUBLIC_TABLE_ORDER_URL=
NEXT_PUBLIC_STORE_TYPE=
NEXT_PUBLIC_BRANCH_ID=
NEXT_PUBLIC_DEFAULT_STORE_TYPE=
NEXT_PUBLIC_DEFAULT_BRANCH_ID=
NEXT_PUBLIC_ENABLE_QUERY_DEVTOOLS=
CAPACITOR_SERVER_URL=
