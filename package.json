{
    "name": "table-order-monorepo",
    "private": true,
    "packageManager": "pnpm@9.15.0",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "dev": "turbo dev --filter=!toss-pos-plugin",
        "build": "turbo build",
        "lint": "turbo lint",
        "test": "turbo test",
        "type-check": "turbo type-check",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:report": "playwright show-report",
        "supa:start": "pnpm supabase start",
        "supa:stop": "pnpm supabase stop",
        "supa:status": "pnpm supabase status",
        "supa:pull-data": "node scripts/pull-db.js"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "next": "16.1.1",
        "turbo": "^2.7.2"
    }
}