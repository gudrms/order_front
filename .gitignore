all-in-one-shared.env.local    # 실값 → gitignore
backend-env.env                # 실값 → gitignore
*.env.local                    # 모든 *.env.local
*-env.env                      # *-env.env 패턴 전부 차단

# 앱별 로컬 env (sync-env.js 가 생성)
apps/*/.env.local
apps/**/.env.local

# Supabase direct / pooler 연결 파일
apps/backend/.env.direct
apps/backend/.env.pooler

# 예시 템플릿은 커밋 허용
